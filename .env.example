# The core runs without a generation model and returns an evidence graph.
# To enable abstraction, relation classification, grounded answers, and
# model-assisted shortcut naming, configure any OpenAI-compatible endpoint.
AEC_LLM_BASE_URL=
AEC_LLM_MODEL=
AEC_LLM_API_KEY=

# Embeddings: hashing (dependency-free demo), sentence_transformers, or openai.
AEC_EMBEDDING_PROVIDER=hashing
AEC_EMBEDDING_MODEL=
AEC_EMBEDDING_DIMENSION=384
AEC_EMBEDDING_BASE_URL=
AEC_EMBEDDING_API_KEY=

# Vector storage: sqlite (built in) or qdrant.
AEC_VECTOR_STORE=sqlite
AEC_QDRANT_URL=
AEC_QDRANT_PATH=
AEC_DATA_DIR=./data

